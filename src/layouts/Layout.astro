---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Manuel Escalera — Full Stack Developer',
  description = 'Portafolio de Manuel Escalera, desarrollador Full Stack con más de 3 años de experiencia en el ecosistema JavaScript: React, Next.js, TypeScript y Node.js.',
} = Astro.props;

const siteUrl = 'https://manuelescalera.dev';
const ogImage = `${siteUrl}/og-image.svg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Manuel Escalera" />

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Preload critical assets -->
    <link rel="preload" href="/fonts/Khand-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/MEVoxelArt-v2.glb" as="fetch" crossorigin />
    <link rel="preload" href="/draco/draco_decoder.wasm" as="fetch" crossorigin />
    <link rel="preload" href="/draco/draco_wasm_wrapper.js" as="script" />


    <!-- Dark mode FOUC prevention: apply theme class before paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('darkMode');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'true' || (stored === null && prefersDark)) {
          document.documentElement.classList.add('dark-mode');
        } else {
          document.documentElement.classList.add('light-mode');
        }
      })();
    </script>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
